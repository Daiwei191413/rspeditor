---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResourceCard from '../components/ResourceCard.astro';
import { featuredPrompts, featuredCapcuts } from '../data/resources';
const title = 'RSP Editor - Free AI Photo Editing Prompts & CapCut Templates';
const description = 'Discover free AI photo editing prompts, ChatGPT and Gemini prompts, and trending CapCut templates for Instagram Reels, YouTube Shorts, TikTok, and WhatsApp status.';
const schema = { '@context': 'https://schema.org', '@type': 'WebSite', name: 'RSP Editor', url: 'https://rspeditor.com', potentialAction: { '@type': 'SearchAction', target: 'https://rspeditor.com/search/?q={search_term_string}', 'query-input': 'required name=search_term_string' } };
const heroTags = ['cinematic','attitude','couple','beat-sync','birthday','lofi'];
---
<BaseLayout title={title} description={description} schema={schema} image="/images/photos/hero-portrait.webp">
  <section class="relative overflow-hidden py-10 md:py-20">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,.18),transparent_34%),radial-gradient(circle_at_80%_18%,rgba(217,70,239,.14),transparent_32%),linear-gradient(180deg,rgba(15,23,42,.2),rgba(15,23,42,1))]"></div>
    <div class="container grid gap-10 lg:grid-cols-[1.1fr_.9fr] lg:items-center">
      <div>
        <h1 class="mt-2 max-w-4xl text-4xl font-black tracking-tight text-white sm:text-5xl md:text-6xl">Free AI Photo Editing Prompts & CapCut Templates</h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-slate-300 md:text-lg md:leading-8">Copy viral ChatGPT and Gemini photo prompts, discover trending CapCut template ideas, and create Instagram Reels, YouTube Shorts, TikTok videos, and WhatsApp status edits faster.</p>
        <p class="mt-4 text-sm text-slate-400">Free to copy · No login required · Updated weekly</p>
        <form action="/search/" class="mt-7 flex max-w-xl flex-col gap-3 sm:flex-row">
          <input name="q" class="min-w-0 flex-1" placeholder="Search cinematic, attitude, cricket, Hindi song..." />
          <button class="btn-primary" type="submit">Search</button>
        </form>
        <div class="mt-5 flex flex-col gap-4 sm:flex-row">
          <a href="/ai-photo-editing-prompts/" class="btn-primary shadow-xl shadow-cyan-950/30">Browse AI Prompts</a>
          <a href="/capcut-templates/" class="btn-secondary">Explore CapCut Templates</a>
        </div>
        <div class="mt-6 flex flex-wrap gap-2">
          {heroTags.map((tag) => <a class="badge shrink-0" href={`/tag/${tag}/`}>{tag}</a>)}
        </div>
      </div>
      <div class="relative hidden lg:block">
        <div class="absolute -inset-6 rounded-[2rem] bg-cyan-300/5 blur-2xl"></div>
        <img src="/images/photos/hero-portrait.webp" alt="Wedding couple portrait style preview for AI photo editing" width="800" height="1000" class="relative mx-auto max-h-[520px] w-auto rounded-2xl object-cover shadow-2xl shadow-black/40" loading="eager" decoding="async" />
        <span class="absolute bottom-4 left-1/2 -translate-x-1/2 rounded-full border border-white/10 bg-slate-900/80 px-4 py-1.5 text-xs font-medium text-slate-300 backdrop-blur">Generated with: Wedding Couple Portrait prompt</span>
      </div>
    </div>
  </section>

  <section class="container grid gap-6 md:grid-cols-2">
    <a href="/ai-photo-editing-prompts/" class="card group p-8 transition hover:-translate-y-1 hover:border-cyan-300/35"><span class="badge">Prompt library</span><h2 class="mt-4 text-3xl font-black text-white group-hover:text-cyan-100">AI Photo Editing Prompts</h2><p class="mt-3 text-slate-300">Ready-to-copy prompts for ChatGPT, Gemini, and AI image editors.</p></a>
    <a href="/capcut-templates/" class="card group p-8 transition hover:-translate-y-1 hover:border-cyan-300/35"><span class="badge">Template guides</span><h2 class="mt-4 text-3xl font-black text-white group-hover:text-cyan-100">CapCut Templates</h2><p class="mt-3 text-slate-300">Trending template guides for Reels, Shorts, TikTok, and status videos.</p></a>
  </section>
  <section class="container mt-16"><div class="mb-6 flex items-end justify-between gap-4"><div><span class="badge">Curated</span><h2 class="mt-3 text-3xl font-black text-white">Latest AI Prompts</h2><p class="mt-2 text-sm text-slate-400">Showing 6 popular prompts while we polish the full library.</p></div><a class="btn-secondary hidden py-2 text-sm sm:inline-flex" href="/ai-photo-editing-prompts/">View all</a></div><div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">{featuredPrompts.slice(0, 6).map((resource) => <ResourceCard resource={resource} visualVariant="clean" />)}</div></section>
  <section class="container mt-16"><div class="mb-6 flex items-end justify-between gap-4"><div><span class="badge">Curated</span><h2 class="mt-3 text-3xl font-black text-white">Trending CapCut Templates</h2><p class="mt-2 text-sm text-slate-400">Showing 6 popular templates while we polish the full library.</p></div><a class="btn-secondary hidden py-2 text-sm sm:inline-flex" href="/capcut-templates/">View all</a></div><div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">{featuredCapcuts.slice(0, 6).map((resource) => <ResourceCard resource={resource} visualVariant="clean" />)}</div></section>
  <section class="container mt-16 prose-lite"><h2>FAQ</h2><h3>Are these AI photo editing prompts free?</h3><p>Yes. You can copy the prompts and use them with supported AI image editors.</p><h3>Can I use these prompts in ChatGPT and Gemini?</h3><p>Most prompts are written for ChatGPT image tools and Gemini-style image editing workflows.</p><h3>Are CapCut templates hosted here?</h3><p>We provide template guides and links to public template sources where available. We do not host stolen files.</p></section>
</BaseLayout>
