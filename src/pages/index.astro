---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResourceCard from '../components/ResourceCard.astro';
import { prompts, capcuts, allTags } from '../data/resources';
const title = 'RSP Editor - Free AI Photo Editing Prompts & CapCut Templates';
const description = 'Discover free AI photo editing prompts, ChatGPT and Gemini prompts, and trending CapCut templates for Instagram Reels, YouTube Shorts, TikTok, and WhatsApp status.';
const schema = { '@context': 'https://schema.org', '@type': 'WebSite', name: 'RSP Editor', url: 'https://rspeditor.com', potentialAction: { '@type': 'SearchAction', target: 'https://rspeditor.com/search/?q={search_term_string}', 'query-input': 'required name=search_term_string' } };
---
<BaseLayout title={title} description={description} schema={schema}>
  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,.22),transparent_35%),radial-gradient(circle_at_80%_20%,rgba(217,70,239,.18),transparent_30%)]"></div>
    <div class="container grid gap-10 lg:grid-cols-[1.15fr_.85fr] lg:items-center">
      <div>
        <span class="badge">For South Asian creators</span>
        <h1 class="mt-5 max-w-4xl text-4xl font-black tracking-tight text-white md:text-6xl">Free AI Photo Editing Prompts & CapCut Templates</h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">Copy viral ChatGPT and Gemini photo prompts, discover trending CapCut template ideas, and create Instagram Reels, YouTube Shorts, TikTok videos, and WhatsApp status edits faster.</p>
        <form action="/search/" class="mt-8 flex max-w-xl gap-3">
          <input name="q" class="flex-1" placeholder="Search cinematic, attitude, cricket, Hindi song..." />
          <button class="btn-primary" type="submit">Search</button>
        </form>
        <div class="mt-5 flex flex-wrap gap-2">{['cinematic','attitude','viral','couple','beat-sync','cricket','birthday','poster','travel','avatar','bike','lofi'].map((tag) => <a class="badge" href={`/tag/${tag}/`}>{tag}</a>)}</div>
      </div>
      <div class="card p-6">
        <div class="rounded-3xl bg-slate-900 p-5">
          <p class="text-sm font-bold text-cyan-200">Copy-ready prompt</p>
          <pre id="hero-prompt" class="prompt-box mt-4">Create a cinematic sunset portrait from my uploaded photo. Keep my face realistic, add golden hour lighting, soft background blur, stylish outfit, and Instagram-ready 4:5 composition.</pre>
          <button class="btn-primary mt-4 w-full" data-copy="#hero-prompt">Copy Prompt</button>
        </div>
      </div>
    </div>
  </section>
  <section class="container grid gap-6 md:grid-cols-2">
    <a href="/ai-photo-editing-prompts/" class="card p-8"><h2 class="text-3xl font-black text-white">AI Photo Editing Prompts</h2><p class="mt-3 text-slate-300">Ready-to-copy prompts for ChatGPT, Gemini, and AI image editors.</p></a>
    <a href="/capcut-templates/" class="card p-8"><h2 class="text-3xl font-black text-white">CapCut Templates</h2><p class="mt-3 text-slate-300">Trending template guides for Reels, Shorts, TikTok, and status videos.</p></a>
  </section>
  <section class="container mt-16"><h2 class="mb-6 text-3xl font-black text-white">Latest AI Prompts</h2><div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">{prompts.slice(0, 9).map((resource) => <ResourceCard resource={resource} />)}</div></section>
  <section class="container mt-16"><h2 class="mb-6 text-3xl font-black text-white">Trending CapCut Templates</h2><div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">{capcuts.slice(0, 6).map((resource) => <ResourceCard resource={resource} />)}</div></section>
  <section class="container mt-16 prose-lite"><h2>FAQ</h2><h3>Are these AI photo editing prompts free?</h3><p>Yes. You can copy the prompts and use them with supported AI image editors.</p><h3>Can I use these prompts in ChatGPT and Gemini?</h3><p>Most prompts are written for ChatGPT image tools and Gemini-style image editing workflows.</p><h3>Are CapCut templates hosted here?</h3><p>We provide template guides and links to public template sources where available. We do not host stolen files.</p></section>
</BaseLayout>
