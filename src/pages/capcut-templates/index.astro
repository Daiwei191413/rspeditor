---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import { featuredCapcuts } from '../../data/resources';
---
<BaseLayout title="Free CapCut Templates for ChatGPT & Gemini | RSP Editor" description="Find trending CapCut template guides for Instagram Reels, YouTube Shorts, TikTok, and WhatsApp status.">
  <section class="container py-14"><span class="badge">Curated popular templates</span><h1 class="mt-4 text-4xl font-black text-white md:text-5xl">CapCut Templates</h1><p class="mt-4 max-w-2xl text-slate-300">Browse template ideas for Hindi songs, Punjabi songs, attitude reels, love edits, birthday videos, and beat sync posts.</p><p class="mt-3 text-sm font-semibold text-cyan-100">Showing 14 popular templates. More template guides are being reviewed and added weekly.</p></section>
  <section class="container grid gap-3 md:grid-cols-2 lg:grid-cols-3">{featuredCapcuts.map((resource) => <ResourceCard resource={resource} visualVariant="clean" />)}</section>
</BaseLayout>
