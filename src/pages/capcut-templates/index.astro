---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import { capcuts } from '../../data/resources';
---
<BaseLayout title="Free CapCut Templates for ChatGPT & Gemini | RSP Editor" description="Find trending CapCut template guides for Instagram Reels, YouTube Shorts, TikTok, and WhatsApp status.">
  <section class="container py-14"><span class="badge">Copy free</span><h1 class="mt-4 text-4xl font-black text-white md:text-5xl">CapCut Templates</h1><p class="mt-4 max-w-2xl text-slate-300">Browse template ideas for Hindi songs, Punjabi songs, attitude reels, love edits, birthday videos, and beat sync posts.</p></section>
  <section class="container grid gap-6 md:grid-cols-2 lg:grid-cols-3">{capcuts.map((resource) => <ResourceCard resource={resource} />)}</section>
</BaseLayout>
